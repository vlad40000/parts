DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DATABASE?sslmode=require

# Internal worker self-call.
# Set this to the deployed origin that hosts api/extract/cold-sync.py.
# Alternatively, expose VERCEL_URL in the project environment.
INTERNAL_APP_URL=https://parts-hazel.vercel.app

# Vercel Deployment Protection bypass for the server-to-server worker request.
# Generate this under Project Settings > Deployment Protection.
VERCEL_AUTOMATION_BYPASS_SECRET=your_bypass_secret_here

# Gemini extraction and OCR routes.
GEMINI_API_KEY=your_key_here
